<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema base de la aplicación -->
    <style name="Theme.ParkingApp" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Tema de Splash Screen -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Color de fondo del splash (Naranja - Color primario) -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>

        <!-- Icono animado del splash -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_car</item>

        <!-- Duración de la animación del icono -->
        <item name="windowSplashScreenAnimationDuration">500</item>

        <!-- Tema que se aplicará después del splash -->
        <item name="postSplashScreenTheme">@style/Theme.ParkingApp</item>
    </style>
</resources>
